# Local-dev config for running the operator outside a Helm install (cargo run -p openhpa-operator).
# In production these come from Helm values / k8s Secrets, not a .env file. Never commit .env.

# Logging
RUST_LOG=info,openhpa_operator=debug

# Kube access for local dev (defaults to ~/.kube/config)
# KUBECONFIG=/Users/you/.kube/config

# Operating mode: recommend (only emit recommendations, never mutate - even an approved CR) or apply
# (also patch approved targets). Recommend-only is the safe default for a first rollout.
OPENHPA_MODE=recommend

# Which namespaces to watch (comma-separated; empty = all)
OPENHPA_WATCH_NAMESPACES=default

# Seconds between reconcile ticks (also drives the leader lease duration = 3x this).
OPENHPA_INTERVAL_SECONDS=300
# Estimated monthly cost (USD) of one always-on replica, pricing the projected-savings estimates (> 0).
OPENHPA_COST_PER_REPLICA_USD_MONTHLY=30

# Metric history. With a Prometheus URL the operator backfills weeks of real history per workload on
# every tick (survives restart); empty falls back to slow per-tick HPA-status accumulation.
# OPENHPA_PROMETHEUS_URL=http://prometheus.monitoring:9090
OPENHPA_METRICS_WINDOW_DAYS=14
OPENHPA_METRICS_STEP_SECONDS=300
# PromQL overrides ({ns}/{deploy} placeholders); default to kube-state-metrics + cAdvisor.
# OPENHPA_PROMQL_CPU=
# OPENHPA_PROMQL_REPLICAS=
# OPENHPA_PROMQL_QUEUE=

# Apply -> probation -> verify safety net (auto-revert a change whose workload health degrades).
OPENHPA_PROBATION_WINDOW_MINUTES=45
OPENHPA_ROLLBACK_ENABLED=true
OPENHPA_HEALTH_CPU_MARGIN=0.15

# Leader election (coordination.k8s.io Lease) so replicas: 2+ never double-apply.
OPENHPA_ENABLE_LEADER_ELECTION=true
OPENHPA_LEASE_NAME=openhpa-leader
# Lease namespace; empty = the operator's own namespace.
OPENHPA_LEASE_NAMESPACE=

# Predictive scaling: forecast recurring peaks and pre-scale the floor ahead of them (off until
# validated). Needs Prometheus history + a real periodic signal; flat/random workloads stay reactive.
OPENHPA_ENABLE_FORECASTING=false
OPENHPA_FORECAST_MIN_HISTORY_DAYS=14
OPENHPA_FORECAST_BIN_MINUTES=60
OPENHPA_FORECAST_QUANTILE=0.95
OPENHPA_PERIODICITY_THRESHOLD=0.3
OPENHPA_PRESCALE_LEAD_MINUTES=10

# LLM backend: openai | anthropic | none (rules-only). bedrock is planned, not yet wired.
OPENHPA_LLM_PROVIDER=none   # none = rules-only, zero egress; openai/anthropic enable optional LLM explanations
OPENHPA_LLM_MODEL=gpt-4o-mini
# Override the LLM API base URL (empty = the provider's real endpoint); point at a proxy/mock/local model.
# OPENHPA_LLM_BASE_URL=
# Per-request LLM timeout (seconds); a stalled model can't stretch a reconcile pass.
OPENHPA_LLM_TIMEOUT_SECONDS=30
# Max concurrent LLM calls during the analysis pass.
OPENHPA_LLM_CONCURRENCY=4
# Time budget (seconds) for the analysis pass's LLM phase; unset = one reconcile interval.
# OPENHPA_ANALYSIS_BUDGET_SECONDS=
# BYO key (egress). Leave OPENHPA_LLM_PROVIDER=none (the default) for rules-only, zero-egress mode.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
